---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
import ChatBot from '../components/ChatBot';
import { Shield, Code2, Cloud, Laptop, Smartphone, Award } from 'lucide-react';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Owen Maake | DevSecOps Portfolio</title>
    <meta name="description" content="Full Stack Developer & Cybersecurity Analyst specializing in building resilient applications and monitoring SOC environments." />
    <RequiredB12HeadScripts />
  </head>

  <body class="dark bg-background">
    <Header />

    <!-- Hero Section -->
    <section id="hero" class="relative min-h-screen flex items-center pt-20 pb-20">
      <div class="max-w-6xl mx-auto px-6 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Hero Text -->
          <div class="space-y-6">
            <!-- Status Label -->
            <div class="inline-block">
              <span class="font-mono text-sm uppercase tracking-widest text-green-cyber/80">
                Status: Active & Seeking Opportunities
              </span>
            </div>

            <!-- Main Headline -->
            <h1 class="text-5xl lg:text-6xl font-bold text-foreground leading-tight">
              Building Secure<br />Digital Infrastructure.
            </h1>

            <!-- Subcopy -->
            <p class="text-lg text-muted-foreground leading-relaxed max-w-lg">
              I'm Owen Maake, a Full Stack Developer & Cybersecurity Analyst specializing in building resilient applications and monitoring SOC environments.
            </p>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 pt-6">
              <a href="/index#contact" class="px-6 py-3 bg-green-cyber text-background font-mono font-semibold rounded-lg hover:shadow-lg hover:shadow-green-cyber/30 transition-all duration-300 text-center">
                Start a Project
              </a>
              <a href="#work" class="px-6 py-3 border border-cyan-electric/50 text-cyan-electric font-mono font-semibold rounded-lg hover:bg-cyan-electric/10 transition-all duration-300 text-center">
                View Laboratory
              </a>
            </div>
          </div>

          <!-- Right: Visualization -->
          <div class="relative h-96 lg:h-full min-h-96">
            <div class="absolute inset-0 gradient-orb rounded-full blur-3xl opacity-50"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="w-64 h-64 rounded-full border-2 border-cyan-electric/20 flex items-center justify-center">
                <div class="w-48 h-48 rounded-full border border-green-cyber/20 flex items-center justify-center">
                  <div class="w-32 h-32 rounded-full bg-gradient-to-br from-green-cyber/10 to-cyan-electric/10 border border-green-cyber/30"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="py-20 border-t border-cyan-electric/20">
      <div class="max-w-4xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <!-- Left: Text Content -->
          <div class="space-y-6">
            <h2 class="text-4xl font-bold text-foreground">About Me</h2>
            <p class="text-muted-foreground leading-relaxed">
              I'm Owen Maake, an IT graduate with a passion for building robust digital solutions while maintaining the highest security standards. My journey combines full-stack development expertise with deep cybersecurity knowledge.
            </p>
            <p class="text-muted-foreground leading-relaxed">
              With hands-on experience in MERN stack development, cloud infrastructure deployment, and SOC operations, I create applications that are not only feature-rich but also secure by design. I believe that security should never be an afterthought.
            </p>
            <p class="text-muted-foreground leading-relaxed">
              When I'm not coding or analyzing security threats, I'm continuously learning new technologies and contributing to the cybersecurity community through hands-on labs and vulnerability research.
            </p>
            <div class="flex gap-4 pt-4">
              <div class="text-center">
                <p class="text-2xl font-bold text-green-cyber">5+</p>
                <p class="text-muted-foreground text-sm">Projects Completed</p>
              </div>
              <div class="text-center">
                <p class="text-2xl font-bold text-cyan-electric">7</p>
                <p class="text-muted-foreground text-sm">Certifications</p>
              </div>
              <div class="text-center">
                <p class="text-2xl font-bold text-green-cyber">2+</p>
                <p class="text-muted-foreground text-sm">Years Experience</p>

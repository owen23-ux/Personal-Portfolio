                  <p class="text-muted-foreground text-xs">Building end-to-end solutions</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-cyan-electric mt-1">▸</span>
                <div>
                  <p class="text-foreground font-mono text-sm">Cybersecurity Analyst</p>
                  <p class="text-muted-foreground text-xs">SOC operations and threat detection</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-green-cyber mt-1">▸</span>
                <div>
                  <p class="text-foreground font-mono text-sm">Cloud Architect</p>
                  <p class="text-muted-foreground text-xs">Deploying secure cloud infrastructure</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-cyan-electric mt-1">▸</span>
                <div>
                  <p class="text-foreground font-mono text-sm">Continuous Learner</p>
                  <p class="text-muted-foreground text-xs">Pursuing advanced security certifications</p>

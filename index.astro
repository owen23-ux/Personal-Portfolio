            </ul>
          </div>

          <!-- Security & SOC Operations Card -->
          <div class="neon-border neon-hover p-6 rounded-lg bg-card/50 backdrop-blur-sm">
            <div class="mb-4 text-green-cyber">
              <Shield size={40} />
            </div>
            <h3 class="font-mono font-bold text-lg mb-3 text-foreground">
              Security & SOC Ops
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed mb-4">

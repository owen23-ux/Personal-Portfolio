          <p class="text-muted-foreground max-w-2xl mx-auto">Creating digital solutions with security at the core.</p>
        </div>

        <!-- Expertise Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Web Design & Development Card -->
          <div class="neon-border neon-hover p-6 rounded-lg bg-card/50 backdrop-blur-sm">
            <div class="mb-4 text-cyan-electric">
              <Laptop size={40} />
            </div>
            <h3 class="font-mono font-bold text-lg mb-3 text-foreground">
              Web Design & Development
            </h3>
            <p class="text-muted-foreground text-sm leading-relaxed mb-4">
              Creating beautiful, responsive, and user-friendly websites that deliver exceptional user experiences across all devices.

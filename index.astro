            <ul class="space-y-2">
              <li class="text-muted-foreground text-xs flex items-center gap-2">
                <span class="text-green-cyber">✓</span> Responsive Design
              </li>
              <li class="text-muted-foreground text-xs flex items-center gap-2">
                <span class="text-green-cyber">✓</span> UI/UX Development
              </li>
              <li class="text-muted-foreground text-xs flex items-center gap-2">
                <span class="text-green-cyber">✓</span> Performance Optimization
              </li>
            </ul>
          </div>


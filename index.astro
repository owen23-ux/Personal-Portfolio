    <!-- Work Section -->
    <section id="work" class="py-20 border-t border-cyan-electric/20">
      <div class="max-w-6xl mx-auto px-6">
        <!-- Section Title -->
        <div class="text-center mb-16">
          <h2 class="text-4xl font-bold text-foreground mb-4">Featured Projects</h2>
          <p class="text-muted-foreground max-w-2xl mx-auto">Real-world applications I've built.</p>
        </div>

        <!-- Work Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Project Card 1: Calculator App -->
          <div class="neon-border neon-hover p-6 rounded-lg bg-card/50 backdrop-blur-sm">
            <h3 class="font-mono font-bold text-lg text-foreground mb-3">
              Calculator App
            </h3>
            <p class="text-muted-foreground text-sm mb-4">
